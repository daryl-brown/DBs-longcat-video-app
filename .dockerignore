# =============================================================================
# .dockerignore — LongCat-Video Avatar
# =============================================================================

# Version control
.git
.gitignore

# Python caches
__pycache__
*.pyc
*.pyo

# Virtual environments
venv/
.venv/

# IDE files
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Output directories (not needed in build)
outputs/
audio_temp/

# Build/deploy scripts (not needed in image)
build.sh
push.sh
test_local.sh
deploy_from_deepagent.sh

# Documentation (not needed in image)
*.md
*.pdf
*.txt
LICENSE
GITHUB_PUSH_COMMANDS.txt

# Docker compose (not needed in image)
docker-compose.yml

# Model weights (downloaded during build from HuggingFace, NOT from repo)
repo/weights/

# Misc
.abacus.donotdelete
